---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
    line1: string;
    attribution: string;
    icon: ImageMetadata;
    figure: ImageMetadata;
    figureAlt: string;
}

const { line1, attribution, icon, figure, figureAlt } = Astro.props;
---

<section
    class="ac-npc-scene relative overflow-hidden rounded-ac-lg border-2 border-ac-border bg-gradient-to-b from-base-100 to-ac-cream-dark/80 px-4 py-3 shadow-ac md:px-5 md:py-4"
>
    <div
        class="pointer-events-none absolute -right-6 -top-4 h-20 w-20 rounded-full bg-ac-primary/10 blur-2xl"
        aria-hidden="true"
    >
    </div>

    <div
        class="relative grid grid-cols-1 items-start gap-3 lg:grid-cols-[1fr_auto] lg:gap-5"
    >
        <div class="w-full lg:col-start-1 lg:row-start-1">
            <div
                class="ac-speech-bubble relative rounded-ac-md border-2 border-ac-border bg-base-100 px-3.5 py-3 shadow-ac md:px-4 md:py-3.5"
            >
                <div class="flex gap-3">
                    <div
                        class="shrink-0 rounded-ac-sm border-2 border-ac-sand bg-ac-cream p-1 shadow-sm"
                    >
                        <Image
                            src={icon}
                            alt=""
                            class="h-10 w-10 object-contain md:h-11 md:w-11"
                            width={44}
                            height={44}
                        />
                    </div>
                    <div
                        class="min-w-0 flex-1 space-y-1.5 text-sm leading-snug md:text-base"
                    >
                        <p class="font-medium text-ac-text-dark">{line1}</p>
                        <p class="text-xs text-ac-text-light md:text-sm">
                            {attribution}
                        </p>
                    </div>
                </div>
            </div>
        </div>

        <div
            class="flex justify-center lg:col-start-2 lg:row-start-1 lg:items-end lg:self-end"
        >
            <Image
                src={figure}
                alt={figureAlt}
                class="ac-npc-figure h-auto w-auto max-h-[min(28vh,200px)] max-w-[160px] object-contain object-bottom drop-shadow-[0_8px_16px_rgba(135,115,88,0.18)] sm:max-h-[min(32vh,220px)] sm:max-w-[180px] lg:max-h-[min(34vh,240px)] lg:max-w-[190px]"
                widths={[300, 400, 600]}
                sizes="(max-width: 1024px) 180px, 190px"
            />
        </div>
    </div>
</section>

<style>
    .ac-speech-bubble::before {
        content: "";
        position: absolute;
        top: 1.25rem;
        left: -0.55rem;
        width: 0.75rem;
        height: 0.75rem;
        background: var(--fallback-b1, #fff);
        border-left: 2px solid var(--ac-border, #ddd6c0);
        border-top: 2px solid var(--ac-border, #ddd6c0);
        transform: rotate(-45deg);
        border-top-left-radius: 3px;
    }

    .ac-npc-figure {
        animation: ac-npc-float 4s ease-in-out infinite;
    }

    @keyframes ac-npc-float {
        0%,
        100% {
            transform: translateY(0);
        }
        50% {
            transform: translateY(-4px);
        }
    }
</style>
