---
import BaseLayout from "../layouts/BaseLayout.astro";
import { AUTHOR_INITIAL, url } from "../config";
---

<BaseLayout title={AUTHOR_INITIAL + " | 鸣谢"} sideBarActiveItemID="thanks">
    <div class="thanks-island pb-10">
        <section class="overflow-hidden rounded-ac-xl border-2 border-ac-border bg-base-100 shadow-ac">
            <div class="thanks-hero relative p-6 text-center md:p-8">
                <div class="mx-auto flex h-20 w-20 items-center justify-center rounded-[42%_58%_48%_52%] border-4 border-white bg-ac-yellow/80 text-4xl shadow-ac">
                    🏝️
                </div>
                <p class="mt-5 text-sm font-bold tracking-[0.24em] text-ac-primary-dark">ISLAND CREDITS</p>
                <h1 class="mt-2 text-3xl font-extrabold text-ac-text-dark md:text-4xl">岛屿落成・鸣谢公告</h1>
                <p class="mx-auto mt-4 max-w-2xl text-sm leading-7 text-ac-text-light md:text-base">
                    由衷感谢各方助力，让这座小小岛屿得以顺利搭建上线。
                </p>
            </div>
        </section>

        <div class="mt-6 grid gap-5 md:grid-cols-2">
            <section class="thanks-card rounded-ac-xl border-2 border-ac-border bg-base-100 p-5 shadow-ac">
                <div class="flex items-start gap-4">
                    <span class="thanks-icon bg-ac-primary/15 text-ac-primary-dark">✨</span>
                    <div>
                        <h2 class="text-xl font-bold text-ac-text-dark">部署支持</h2>
                        <p class="mt-2 text-sm leading-7 text-ac-text-light">感谢 GitHub、Vercel 提供稳定的线上部署服务。</p>
                    </div>
                </div>
            </section>

            <section class="thanks-card rounded-ac-xl border-2 border-ac-border bg-base-100 p-5 shadow-ac">
                <div class="flex items-start gap-4">
                    <span class="thanks-icon bg-ac-green-light/60 text-ac-text-dark">🔗</span>
                    <div>
                        <h2 class="text-xl font-bold text-ac-text-dark">接口服务</h2>
                        <p class="mt-2 text-sm leading-7 text-ac-text-light">Spotify Web API、Steam Web API。</p>
                    </div>
                </div>
            </section>

            <section class="thanks-card rounded-ac-xl border-2 border-ac-border bg-base-100 p-5 shadow-ac md:col-span-2">
                <div class="flex items-start gap-4">
                    <span class="thanks-icon bg-ac-yellow/70 text-ac-text-dark">📦</span>
                    <div class="min-w-0 flex-1">
                        <h2 class="text-xl font-bold text-ac-text-dark">源码项目</h2>
                        <div class="mt-3 grid gap-2 text-sm sm:grid-cols-2">
                            <a class="credit-link" href="https://github.com/yunxinz/ac-site-template" target="_blank" rel="noreferrer">github.com/yunxinz/ac-site-template</a>
                            <a class="credit-link" href="https://github.com/guokaigdg/animal-island-ui" target="_blank" rel="noreferrer">github.com/guokaigdg/animal-island-ui</a>
                        </div>
                    </div>
                </div>
            </section>

            <section class="thanks-card rounded-ac-xl border-2 border-ac-border bg-base-100 p-5 shadow-ac">
                <div class="flex items-start gap-4">
                    <span class="thanks-icon bg-ac-pink/40 text-ac-text-dark">🤖</span>
                    <div>
                        <h2 class="text-xl font-bold text-ac-text-dark">智能创作</h2>
                        <p class="mt-2 text-sm leading-7 text-ac-text-light">豆包、DeepSeek、GPT 各类 AI 工具助力内容与开发创作。</p>
                    </div>
                </div>
            </section>

            <section class="thanks-card rounded-ac-xl border-2 border-ac-border bg-base-100 p-5 shadow-ac">
                <div class="flex items-start gap-4">
                    <span class="thanks-icon bg-ac-orange/50 text-ac-text-dark">🎮</span>
                    <div>
                        <h2 class="text-xl font-bold text-ac-text-dark">灵感本源</h2>
                        <p class="mt-2 text-sm leading-7 text-ac-text-light">感谢《集合啦！动物森友会》带来美好创作灵感。</p>
                    </div>
                </div>
            </section>
        </div>

        <section class="mt-6 rounded-ac-xl border-2 border-ac-border bg-base-100 p-5 shadow-ac md:p-6">
            <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
                <div>
                    <h2 class="text-xl font-bold text-ac-text-dark">补充鸣谢与联络</h2>
                    <p class="mt-2 text-sm leading-7 text-ac-text-light">
                        如若您发现本站取用相关功能、资源却未标注致谢，可通过邮箱联络我。
                    </p>
                </div>
                <a href="mailto:2467535381@qq.com" class="btn-ac whitespace-nowrap">2467535381@qq.com</a>
            </div>
        </section>

        <section class="mt-6 rounded-ac-xl border-2 border-dashed border-ac-border bg-ac-cream/70 p-5 text-center md:p-6">
            <h2 class="text-lg font-bold text-ac-text-dark">📜 免责声明</h2>
            <p class="mx-auto mt-3 max-w-2xl text-xs leading-7 text-ac-text-light md:text-sm">
                本站纯属个人兴趣搭建，无任何商业盈利行为。若存在版权侵权相关问题，欢迎及时联系，我将第一时间妥善处理。
            </p>
        </section>
    </div>
</BaseLayout>

<style>
    .thanks-island {
        position: relative;
    }

    .thanks-island::before {
        background-image: radial-gradient(var(--ac-sand) 1.2px, transparent 1.2px);
        background-size: 18px 18px;
        content: "";
        inset: -1rem;
        opacity: 0.2;
        pointer-events: none;
        position: absolute;
    }

    .thanks-island > * {
        position: relative;
    }

    .thanks-hero {
        background:
            linear-gradient(135deg, rgba(42, 186, 170, 0.16), rgba(255, 241, 118, 0.22)),
            var(--ac-surface);
    }

    .thanks-card {
        transition: transform 0.18s ease, border-color 0.18s ease, box-shadow 0.18s ease;
    }

    .thanks-card:hover {
        border-color: var(--ac-primary);
        box-shadow: var(--ac-shadow-hover);
        transform: translateY(-3px) rotate(-0.25deg);
    }

    .thanks-icon {
        align-items: center;
        border: 2px solid var(--ac-border);
        border-radius: var(--ac-radius-lg);
        display: inline-flex;
        flex-shrink: 0;
        font-size: 1.5rem;
        height: 3.25rem;
        justify-content: center;
        width: 3.25rem;
    }

    .credit-link {
        background: rgba(42, 186, 170, 0.08);
        border: 2px solid var(--ac-border);
        border-radius: var(--ac-radius-md);
        color: var(--ac-primary-dark);
        display: block;
        font-weight: 700;
        overflow-wrap: anywhere;
        padding: 0.75rem 1rem;
        transition: var(--ac-transition);
    }

    .credit-link:hover {
        background: rgba(42, 186, 170, 0.16);
        border-color: var(--ac-primary);
    }
</style>
