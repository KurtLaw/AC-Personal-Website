---
import BaseLayout from "../layouts/BaseLayout.astro";
import AcNpcScene from "../components/AcNpcScene.astro";
import { AUTHOR_INITIAL, url } from "src/config";
---

<BaseLayout title={AUTHOR_INITIAL + " | Resume"} sideBarActiveItemID="cv">
    <div class="ac-npc-page pb-2 pt-0">
        <div class="mb-2 text-2xl font-bold">简历</div>

        <AcNpcScene
            line1="该岛民简历还在纸箱里没拆封哦"
            attribution="—— 西施惠说：请改天再来看看吧"
            icon={url("cv/Isabelle_NH_Character_Icon.png")}
            figure={url("cv/800px-Isabelle_NH_Transparent.png")}
            figureAlt="西施惠"
        />
    </div>
</BaseLayout>

<style>
    .ac-npc-page {
        max-height: calc(100dvh - 11rem);
    }

    @media (min-width: 1024px) {
        .ac-npc-page {
            max-height: calc(100dvh - 9rem);
        }
    }
</style>
